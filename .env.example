# Agent N9er Environment Configuration
# Copy to .env and customize for your deployment

# Environment profile: development | staging | production
VERIXIO_ENV=development

# API authentication
API_KEY=
SERVICE_TOKEN=

# Dashboard JWT auth
JWT_SECRET=change-this-to-a-random-secret
ADMIN_USER=admin
ADMIN_PASS=change-this-password

# Webhook secrets
GITHUB_WEBHOOK_SECRET=
SLACK_SIGNING_SECRET=

# OpenRouter — LLM execution for task completion
OPENROUTER_API_KEY=

# Sentry — error tracking and performance monitoring (optional)
# SENTRY_DSN=

# Stripe — billing and payment collection
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Autonomous scan scheduler
# AUTO_SCAN_ENABLED=false
# SCAN_INTERVAL_SECONDS=3600
# SCAN_PLATFORMS=upwork,github_bounties,freelancer,algora,topcoder
# AUTO_EVALUATE=false

# Recurring task engine
# AUTO_RECURRING_ENABLED=false
# RECURRING_INTERVAL_SECONDS=300

# Scan rate limiting
# SCAN_RATE_DELAY_SECONDS=5

# GitHub token for bounty scanning (optional, increases rate limits)
# GITHUB_TOKEN=

# Email notifications for high-value prospects
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# NOTIFY_EMAIL=
# NOTIFY_MIN_BUDGET=100

# Delivery service — send completed work to clients
# DELIVERY_FROM_EMAIL=delivery@agentn9er.com
# DELIVERY_FROM_NAME=Agent N9er

# Safety guardrails — spending limits and auto-execution
# MAX_SINGLE_TASK_USD=500.0
# MAX_DAILY_SPEND_USD=2000.0
# REQUIRE_APPROVAL_ABOVE_USD=100.0
# AUTO_EXECUTE_ENABLED=true

# Override defaults (optional)
# MAX_RETRIES=3
# RETRY_BACKOFF=0.3
# DEFAULT_TIMEOUT=10.0
# PIPELINE_TIMEOUT=15.0
# RATE_LIMIT_MAX_REQUESTS=100
# CORS_ORIGINS=http://localhost:3000
# MARKUP_MULTIPLIER=3.0
# MINIMUM_QUOTE_USD=5.0

# Database paths (per-service, defaults work for Docker)
# ORCHESTRATOR_DB_PATH=/data/orchestrator.db
# EXECUTION_DB_PATH=/data/execution.db
# REPUTATION_DB_PATH=/data/reputation.db
# MARKETPLACE_DB_PATH=/data/marketplace.db
# RECURRING_DB_PATH=/data/recurring.db
# BILLING_DB_PATH=/data/billing.db
# EVALUATOR_DB_PATH=/data/evaluator.db
# PROSPECTOR_DB_PATH=/data/prospector.db
# MEMORY_DB_PATH=/data/memory.db
# DELIVERY_DB_PATH=/data/delivery.db
