# Agent N9er Environment Configuration
# Copy to .env and customize for your deployment

# Environment profile: development | staging | production
VERIXIO_ENV=development

# API authentication
API_KEY=
SERVICE_TOKEN=

# Dashboard JWT auth
JWT_SECRET=change-this-to-a-random-secret
ADMIN_USER=admin
ADMIN_PASS=change-this-password

# Webhook secrets
GITHUB_WEBHOOK_SECRET=
SLACK_SIGNING_SECRET=

# LLM provider selection: auto | openrouter | anthropic | openai | azure | gemini
# LLM_PROVIDER=auto

# OpenRouter — LLM execution for task completion
OPENROUTER_API_KEY=

# Anthropic direct
ANTHROPIC_API_KEY=

# OpenAI direct
OPENAI_API_KEY=

# Azure OpenAI / Codex-Microsoft direct
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_BUDGET_DEPLOYMENT=
# AZURE_OPENAI_STANDARD_DEPLOYMENT=
# AZURE_OPENAI_PREMIUM_DEPLOYMENT=

# Gemini direct
GEMINI_API_KEY=

# Stripe — billing and payment collection
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Autonomous scan scheduler
# AUTO_SCAN_ENABLED=false
# SCAN_INTERVAL_SECONDS=3600
# SCAN_PLATFORMS=upwork,github_bounties,freelancer,algora,topcoder
# AUTO_EVALUATE=false

# GitHub token for bounty scanning (optional, increases rate limits)
# GITHUB_TOKEN=

# Email notifications for high-value prospects
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# NOTIFY_EMAIL=
# NOTIFY_MIN_BUDGET=100

# Enterprise tools
# PASSWORD_SALT=change-this-salt-in-production
# ENTERPRISE_DB_PATH=/data/enterprise.db
# AUDIT_DB_PATH=/data/audit.db

# Override defaults (optional)
# MAX_RETRIES=3
# RETRY_BACKOFF=0.3
# DEFAULT_TIMEOUT=10.0
# PIPELINE_TIMEOUT=15.0
# RATE_LIMIT_MAX_REQUESTS=100
# CORS_ORIGINS=http://localhost:3000
# MARKUP_MULTIPLIER=3.0
# MINIMUM_QUOTE_USD=5.0
